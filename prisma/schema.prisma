generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Hanyu {
  id        String   @id @unique
  hanzi     String
  pinyin    String
  xinbanya  String
  riyu      String?
  tone      String?
  img       String?
  source    String?  @default("form-hanyu")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


